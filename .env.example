# ═══════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════
POSTGRES_USER=tabela
POSTGRES_PASSWORD=tabela
POSTGRES_DB=tabela
DATABASE_URL=postgres://tabela:tabela@db:5432/tabela

# ═══════════════════════════════════════════════════════════════
# API
# ═══════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════
# Web
# ═══════════════════════════════════════════════════════════════
WEB_PORT=3001

# ═══════════════════════════════════════════════════════════════
# Frontend (dev only — em prod o nginx faz proxy)
# ═══════════════════════════════════════════════════════════════
VITE_API_URL=http://localhost:3000/tabela/api
VITE_WS_URL=ws://localhost:3000/tabela/ws
